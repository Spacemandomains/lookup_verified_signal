{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/.well-known/(.*)", "destination": "/.well-known/$1" },
    { "source": "/openapi.json", "destination": "/api/index.ts" },
    { "source": "/success", "destination": "/success.html" }
  ]
}
